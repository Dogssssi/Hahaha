--// AUTO LIFT LOOP
--// TOGGLE
--// WALKABLE
--// FAST CYCLE

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

_G.AutoLift = not _G.AutoLift

while _G.AutoLift do

	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")

	local tools = {}

	-- BACKPACK
	for _,tool in pairs(player.Backpack:GetChildren()) do
		if tool:IsA("Tool") and string.find(tool.Name:lower(),"Double Weight") then
			table.insert(tools, tool)
		end
	end

	-- CHARACTER
	for _,tool in pairs(character:GetChildren()) do
		if tool:IsA("Tool") and string.find(tool.Name:lower(),"Double Weight") then
			table.insert(tools, tool)
		end
	end

	-- FAST CYCLE
	for _,tool in pairs(tools) do

		if not _G.AutoLift then
			break
		end

		pcall(function()

			humanoid:EquipTool(tool)

			task.wait(0.02)

			if tool:FindFirstChild("Handle") then
				ReplicatedStorage.addStrength:FireServer(tool.Handle,1)
			else
				ReplicatedStorage.addStrength:FireServer(tool,1)
			end

		end)

		task.wait(0.02)
	end

	task.wait(0.05)
end
